{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on monday"],
  "automergeType": "pr",
  "packageRules": [
    {
      "matchPackagePatterns": ["@fastify/*", "fastify"],
      "groupName": "fastify"
    },
    {
      "matchPackagePatterns": ["@biomejs/*"],
      "groupName": "biome"
    },
    {
      "matchPackagePatterns": ["vitest"],
      "groupName": "vitest"
    },
    {
      "matchPackagePatterns": ["typescript"],
      "groupName": "typescript"
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["flowiseai/flowise"],
      "allowedVersions": "<2.0.0",
      "description": "Flowise v3 does not exist as a Docker tag; pin to 1.x"
    }
  ]
}
