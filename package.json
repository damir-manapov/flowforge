{
  "name": "@flowforge/monorepo",
  "private": true,
  "author": "Damir Manapov",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "typecheck:tests": "tsc -p tsconfig.check.json",
    "compose:pull": "docker compose -f compose/docker-compose.yml pull",
    "compose:up": "docker compose -f compose/docker-compose.yml up -d --wait",
    "compose:down": "docker compose -f compose/docker-compose.yml down",
    "compose:restart": "docker compose -f compose/docker-compose.yml restart",
    "compose:reset": "docker compose -f compose/docker-compose.yml down -v --remove-orphans",
    "compose:up:dev-ui": "docker compose -f compose/docker-compose.dev-ui.yml up -d --wait",
    "compose:down:dev-ui": "docker compose -f compose/docker-compose.dev-ui.yml down -v --remove-orphans",
    "compose:flowise:up": "docker compose -f compose/docker-compose.flowise.yml up -d --wait",
    "compose:flowise:down": "docker compose -f compose/docker-compose.flowise.yml down",
    "compose:record:up": "docker compose -f compose/docker-compose.record.yml up -d --wait",
    "compose:record:down": "docker compose -f compose/docker-compose.record.yml down -v --remove-orphans",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bash all-checks.sh"
  },
  "pnpm": {
    "overrides": {
      "tsx": "-"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
